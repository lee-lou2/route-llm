# Local server. Keep the default bind loopback-only unless you intentionally
# expose the router behind your own trusted reverse proxy.
ROUTE_LLM_BIND=127.0.0.1:8080
ROUTE_LLM_PUBLIC_PREFIX=/v1
ROUTE_LLM_DATABASE_URL=sqlite://data/router.sqlite

# Admin UI. Leave ROUTE_LLM_ADMIN_PASSWORD unset to disable /admin.
ROUTE_LLM_ADMIN_PASSWORD=
ROUTE_LLM_ADMIN_SESSION_SECRET=
ROUTE_LLM_ADMIN_SITE_NAME=Route LLM
ROUTE_LLM_ADMIN_SITE_DESCRIPTION=Local OpenAI-compatible routing proxy

# Optional external URL used only for rendered admin metadata and display text.
# ROUTE_LLM_PUBLIC_BASE_URL=https://router.example.com

# Proxy limits and retry cache behavior.
ROUTE_LLM_REQUEST_TIMEOUT_SECS=300
ROUTE_LLM_TRANSIENT_FAILURE_TTL_SECS=300
ROUTE_LLM_AUTH_FAILURE_TTL_SECS=3600
ROUTE_LLM_MAX_BODY_BYTES=33554432

# Example bootstrap values used by README commands. Do not commit real values.
ROUTE_LLM_CLIENT_TOKEN=
UPSTREAM_NAME=openai-compatible
UPSTREAM_BASE_URL=https://api.example.com/v1
UPSTREAM_API_KEY=
UPSTREAM_MODEL=provider-llm
